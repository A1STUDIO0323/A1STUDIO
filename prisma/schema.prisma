generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model User {
  id        String   @id @db.Uuid
  email     String?  @unique
  name      String?
  nickname  String?  @map("nickname")
  avatarUrl String?  @map("avatar_url")
  provider  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  birthYear       Int?     @map("birth_year") @db.SmallInt
  phone           String?  @unique
  phoneVerified   Boolean  @default(false) @map("phone_verified")
  marketingAgreed Boolean  @default(false) @map("marketing_agreed")

  accounts        Account[]
  sessions        Session[]
  oneDayClassApps OneDayClassApplication[]

  @@map("profiles")
  @@schema("public")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model EmailAuthUser {
  email        String   @id
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("email_auth_users")
  @@schema("public")
}

model PasswordResetToken {
  token     String    @id
  email     String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
  @@schema("public")
}

// ─── 원데이클래스 모델 ─────────────────────────────────────────
enum OneDayClassStatus {
  OPEN // 신청 모집 중
  CONFIRMED // 인원 충족, 확정
  CANCELLED // 취소됨
  COMPLETED // 진행 완료

  @@schema("public")
}

model OneDayClass {
  id              String            @id @default(cuid())
  title           String
  teacherName     String            @map("teacher_name")
  teacherProfile  String            @map("teacher_profile") @db.Text
  teacherImage    String?           @map("teacher_image")
  classType       String            @map("class_type") // VOCAL / DANCE / ACT / MUSICAL
  description     String            @db.Text
  desiredDate     DateTime          @map("desired_date")
  durationMinutes Int               @default(120) @map("duration_minutes")
  minHeadcount    Int               @default(8) @map("min_headcount")
  maxHeadcount    Int               @default(15) @map("max_headcount")
  pricePerPerson  Int               @map("price_per_person")
  status          OneDayClassStatus @default(OPEN)
  confirmedDate   DateTime?         @map("confirmed_date")
  isPublished     Boolean           @default(true) @map("is_published")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  applications OneDayClassApplication[]

  @@map("one_day_classes")
  @@schema("public")
}

model OneDayClassApplication {
  id          String      @id @default(cuid())
  classId     String      @map("class_id")
  class       OneDayClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?     @map("user_id") @db.Uuid
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName   String      @map("guest_name")
  guestPhone  String      @map("guest_phone")
  guestEmail  String?     @map("guest_email")
  headcount   Int         @default(1)
  message     String?
  isCancelled Boolean     @default(false) @map("is_cancelled")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("one_day_class_applications")
  @@schema("public")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  capacity    Int
  sizeM2      Float    @map("size_m2")
  amenities   Json     @default("[]") @map("amenities_json")
  images      Json     @default("[]")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pricingRules PricingRule[]
  reservations Reservation[]
  holds        ReservationHold[]

  @@map("rooms")
  @@schema("public")
}

model PricingRule {
  id            String   @id @default(cuid())
  roomId        String   @map("room_id")
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  label         String
  dayOfWeekMask Int      @map("day_of_week_mask") // bitmask: Sun=1,Mon=2,Tue=4,Wed=8,Thu=16,Fri=32,Sat=64
  timeStart     String   @map("time_start") // "HH:MM"
  timeEnd       String   @map("time_end") // "HH:MM"
  pricePerHour  Int      @map("price_per_hour")
  minHours      Int      @default(1) @map("min_hours")
  isPackage     Boolean  @default(false) @map("is_package")
  packageName   String?  @map("package_name")
  packageHours  Int?     @map("package_hours")
  packagePrice  Int?     @map("package_price")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("pricing_rules")
  @@schema("public")
}

enum ReservationStatus {
  HOLD
  PAID
  CONFIRMED
  CANCELLED
  EXPIRED
  REFUNDED

  @@schema("public")
}

model Reservation {
  id          String            @id @default(cuid())
  roomId      String            @map("room_id")
  room        Room              @relation(fields: [roomId], references: [id])
  userId      String?           @map("user_id") @db.Uuid
  guestName   String            @map("guest_name")
  guestPhone  String            @map("guest_phone")
  guestEmail  String?           @map("guest_email")
  date        String // "YYYY-MM-DD"
  startTime   String            @map("start_time") // "HH:MM"
  endTime     String            @map("end_time") // "HH:MM"
  headcount   Int               @default(1)
  packageType     String?           @map("package_type")
  reservationType String?           @map("reservation_type")
  status      ReservationStatus @default(HOLD)
  totalAmount Int               @map("total_amount")
  memo        String?
  authCode    String?           @map("auth_code") // 비회원 조회용 인증코드
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  hold    ReservationHold?
  payment Payment?
  review  Review?

  @@index([roomId, date])
  @@index([guestPhone])
  @@map("reservations")
  @@schema("public")
}

model ChargePackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  amount      Int
  bonusRate   Float?   @map("bonus_rate")
  bonusPoints Int?     @map("bonus_points")
  totalPoints Int      @map("total_points")
  isPopular   Boolean  @default(false) @map("is_popular")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("charge_packages")
  @@schema("public")
}

model ReservationHold {
  id            String      @id @default(cuid())
  roomId        String      @map("room_id")
  room          Room        @relation(fields: [roomId], references: [id])
  reservationId String      @unique @map("reservation_id")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  date          String
  startTime     String      @map("start_time")
  endTime       String      @map("end_time")
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([roomId, date, startTime, endTime], name: "unique_slot")
  @@map("reservation_holds")
  @@schema("public")
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELLED
  PARTIAL_REFUNDED
  REFUNDED

  @@schema("public")
}

model Payment {
  id                 String        @id @default(cuid())
  reservationId      String        @unique @map("reservation_id")
  reservation        Reservation   @relation(fields: [reservationId], references: [id])
  provider           String        @default("toss")
  providerPaymentKey String?       @map("provider_payment_key")
  orderId            String        @unique @map("order_id")
  amount             Int
  status             PaymentStatus @default(PENDING)
  requestedAt        DateTime      @default(now()) @map("requested_at")
  approvedAt         DateTime?     @map("approved_at")
  rawResponse        Json?         @map("raw_response")

  refunds Refund[]

  @@map("payments")
  @@schema("public")
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED

  @@schema("public")
}

model Refund {
  id          String       @id @default(cuid())
  paymentId   String       @map("payment_id")
  payment     Payment      @relation(fields: [paymentId], references: [id])
  amount      Int
  reason      String
  status      RefundStatus @default(REQUESTED)
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("refunds")
  @@schema("public")
}

model Review {
  id            String      @id @default(cuid())
  reservationId String      @unique @map("reservation_id")
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  rating        Int
  content       String
  nickname      String?
  isVisible     Boolean     @default(false) @map("is_visible")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("reviews")
  @@schema("public")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPublished Boolean  @default(false) @map("is_published")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notices")
  @@schema("public")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  content     String
  thumbnail   String?
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("events")
  @@schema("public")
}

model BlockedSlot {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  date      String
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String   @default("관리자 차단")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId, date])
  @@map("blocked_slots")
  @@schema("public")
}

// 외부 플랫폼 예약 (스페이스클라우드, 네이버 플레이스 등)
model ExternalReservation {
  id         String   @id @default(cuid())
  platform   String   // 'spacecloud', 'naver', etc.
  externalId String?  @map("external_id") // 외부 플랫폼의 예약 ID
  roomType   String   @map("room_type") // 'practice-room' or 'party-room'
  date       String   // "YYYY-MM-DD"
  startTime  String   @map("start_time") // "HH:MM"
  endTime    String   @map("end_time") // "HH:MM"
  guestName  String   @map("guest_name")
  guestPhone String   @map("guest_phone")
  amount     Int      @default(0)
  status     String   @default("confirmed")
  memo       String?
  syncedAt   DateTime @default(now()) @map("synced_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([platform, date])
  @@index([date])
  @@map("external_reservations")
  @@schema("public")
}

// 결제 중복 방지를 위한 락 테이블
model PaymentLock {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  lockType  String   @map("lock_type") // 'charge', 'reservation', 'party-room'
  lockKey   String   @map("lock_key") // 주문 ID 또는 예약 날짜+시간
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, lockType, lockKey])
  @@index([userId, lockType])
  @@index([expiresAt])
  @@map("payment_locks")
  @@schema("public")
}

// 메시지 발송 로그
model MessageLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id") @db.Uuid
  reservationId String?  @map("reservation_id")
  phoneNumber   String   @map("phone_number")
  messageType   String   @map("message_type") // 'reservation_confirm', 'reservation_cancel', 'reminder'
  content       String   @db.Text
  status        String   // 'success', 'failed'
  errorMessage  String?  @map("error_message") @db.Text
  messageId     String?  @map("message_id")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([reservationId])
  @@index([createdAt(sort: Desc)])
  @@map("message_logs")
  @@schema("public")
}

model MemberRole {
  email     String   @id
  role      String // "CM" 등
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("member_roles")
  @@schema("public")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model OneDayClass {
  id              String                   @id @default(cuid())
  title           String
  teacherName     String                   @map("teacher_name")
  teacherProfile  String                   @map("teacher_profile")
  teacherImage    String?                  @map("teacher_image")
  classType       String                   @map("class_type")
  description     String
  desiredDate     DateTime                 @map("desired_date")
  durationMinutes Int                      @default(120) @map("duration_minutes")
  minHeadcount    Int                      @default(8) @map("min_headcount")
  maxHeadcount    Int                      @default(15) @map("max_headcount")
  pricePerPerson  Int                      @map("price_per_person")
  status          OneDayClassStatus        @default(OPEN)
  confirmedDate   DateTime?                @map("confirmed_date")
  isPublished     Boolean                  @default(true) @map("is_published")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  applications    OneDayClassApplication[]

  @@map("one_day_classes")
  @@schema("public")
}

model OneDayClassApplication {
  id          String      @id @default(cuid())
  classId     String      @map("class_id")
  userId      String?     @map("user_id") @db.Uuid
  guestName   String      @map("guest_name")
  guestPhone  String      @map("guest_phone")
  guestEmail  String?     @map("guest_email")
  headcount   Int         @default(1)
  message     String?
  isCancelled Boolean     @default(false) @map("is_cancelled")
  createdAt   DateTime    @default(now()) @map("created_at")
  class       OneDayClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("one_day_class_applications")
  @@schema("public")
}

model Room {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  description       String?
  capacity          Int
  sizeM2            Float               @map("size_m2")
  amenities         Json                @default("[]") @map("amenities_json")
  images            Json                @default("[]")
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  pricingRules      PricingRule[]
  reservation_holds reservation_holds[]
  reservations      Reservation[]

  @@map("rooms")
  @@schema("public")
}

model PricingRule {
  id            String   @id @default(cuid())
  roomId        String   @map("room_id")
  label         String
  dayOfWeekMask Int      @map("day_of_week_mask")
  timeStart     String   @map("time_start")
  timeEnd       String   @map("time_end")
  pricePerHour  Int      @map("price_per_hour")
  minHours      Int      @default(1) @map("min_hours")
  isPackage     Boolean  @default(false) @map("is_package")
  packageName   String?  @map("package_name")
  packageHours  Int?     @map("package_hours")
  packagePrice  Int?     @map("package_price")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
  @@schema("public")
}

model Reservation {
  id                String             @id @default(cuid())
  roomId            String             @map("room_id")
  userId            String?            @map("user_id") @db.Uuid
  guestName         String             @map("guest_name")
  guestPhone        String             @map("guest_phone")
  guestEmail        String?            @map("guest_email")
  date              String
  startTime         String             @map("start_time")
  endTime           String             @map("end_time")
  headcount         Int                @default(1)
  status            ReservationStatus  @default(HOLD)
  totalAmount       Int                @map("total_amount")
  memo              String?
  authCode          String?            @map("auth_code")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  reservationType   String?            @map("reservation_type")
  packageType       String?            @map("package_type")
  payment           Payment?
  reservation_holds reservation_holds?
  room              Room               @relation(fields: [roomId], references: [id])
  reviews           reviews?

  @@index([roomId, date])
  @@index([guestPhone])
  @@map("reservations")
  @@schema("public")
}

model ChargePackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  amount      Int
  bonusRate   Float?   @map("bonus_rate")
  bonusPoints Int?     @map("bonus_points")
  totalPoints Int      @map("total_points")
  isPopular   Boolean  @default(false) @map("is_popular")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("charge_packages")
  @@schema("public")
}

model Payment {
  id                 String        @id @default(cuid())
  reservationId      String        @unique @map("reservation_id")
  provider           String        @default("toss")
  providerPaymentKey String?       @map("provider_payment_key")
  orderId            String        @unique @map("order_id")
  amount             Int
  status             PaymentStatus @default(PENDING)
  requestedAt        DateTime      @default(now()) @map("requested_at")
  approvedAt         DateTime?     @map("approved_at")
  rawResponse        Json?         @map("raw_response")
  reservation        Reservation   @relation(fields: [reservationId], references: [id])
  refunds            Refund[]

  @@map("payments")
  @@schema("public")
}

model Refund {
  id          String       @id @default(cuid())
  paymentId   String       @map("payment_id")
  amount      Int
  reason      String
  status      RefundStatus @default(REQUESTED)
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  payment     Payment      @relation(fields: [paymentId], references: [id])

  @@map("refunds")
  @@schema("public")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPublished Boolean  @default(false) @map("is_published")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notices")
  @@schema("public")
}

model LostItem {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  images      Json     @default("[]")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("lost_items")
  @@schema("public")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  content     String
  thumbnail   String?
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("events")
  @@schema("public")
}

model BlockedSlot {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  date      String
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String   @default("관리자 차단")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId, date])
  @@map("blocked_slots")
  @@schema("public")
}

model ExternalReservation {
  id         String   @id @default(cuid())
  platform   String
  externalId String?  @map("external_id")
  roomType   String   @map("room_type")
  date       String
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  guestName  String   @map("guest_name")
  guestPhone String   @map("guest_phone")
  amount     Int      @default(0)
  status     String   @default("confirmed")
  memo       String?
  syncedAt   DateTime @default(now()) @map("synced_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([platform, date])
  @@index([date])
  @@map("external_reservations")
  @@schema("public")
}

model PaymentLock {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id") @db.Uuid
  lockType  String   @map("lock_type")
  lockKey   String   @map("lock_key")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, lockType, lockKey])
  @@index([expiresAt], map: "idx_payment_locks_expires")
  @@index([userId], map: "idx_payment_locks_user")
  @@map("payment_locks")
  @@schema("public")
}

model MemberRole {
  email     String   @id
  role      String
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("member_roles")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_PaymentLock {
  id        String   @id
  userId    String   @db.Uuid
  lockType  String
  lockKey   String
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([userId, lockType, lockKey])
  @@index([expiresAt], map: "idx_payment_lock_expires")
  @@index([userId], map: "idx_payment_lock_user")
  @@map("PaymentLock")
  @@schema("public")
}

model banned_members {
  email      String   @id
  reason     String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model email_auth_users {
  email         String   @id
  password_hash String
  name          String?
  created_at    DateTime @default(now())
  updated_at    DateTime

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model message_logs {
  id             String   @id
  user_id        String?  @db.Uuid
  reservation_id String?
  phone_number   String
  message_type   String
  content        String
  status         String
  error_message  String?
  message_id     String?
  created_at     DateTime @default(now())

  @@index([created_at(sort: Desc)])
  @@index([reservation_id])
  @@index([user_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model party_reservations {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?   @db.Uuid
  date             DateTime  @db.Date
  start_time       DateTime  @db.Time(6)
  end_time         DateTime  @db.Time(6)
  duration_hours   Decimal   @db.Decimal(4, 2)
  total_amount     Int
  guest_name       String
  guest_phone      String
  guest_email      String?
  headcount        Int?      @default(1)
  status           String?   @default("PAID")
  payment_provider String?
  payment_key      String?
  order_id         String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  cancelled_at     DateTime? @db.Timestamptz(6)

  @@schema("public")
}

model password_reset_tokens {
  token      String    @id
  email      String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([email])
  @@index([expires_at])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model point_transactions {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  type           String
  amount         Int
  balance_after  Int
  description    String?
  reservation_id String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_point_transactions_user")
  @@schema("public")
}

model reservation_holds {
  id             String      @id
  room_id        String
  reservation_id String      @unique
  date           String
  start_time     String
  end_time       String
  expires_at     DateTime
  created_at     DateTime    @default(now())
  reservations   Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  rooms          Room        @relation(fields: [room_id], references: [id])

  @@unique([room_id, date, start_time, end_time])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id             String      @id
  rating         Int
  content        String
  created_at     DateTime    @default(now())
  is_visible     Boolean     @default(false)
  nickname       String?
  reservation_id String      @unique
  reservations   Reservation @relation(fields: [reservation_id], references: [id])

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_points {
  user_id       String    @id @db.Uuid
  balance       Int?      @default(0)
  total_charged Int?      @default(0)
  total_used    Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id               String    @id(map: "profiles_pkey") @db.Uuid
  email            String?   @unique(map: "profiles_email_key")
  name             String?
  avatar_url       String?
  provider         String?
  created_at       DateTime  @default(now())
  updated_at       DateTime
  birth_year       Int?      @db.SmallInt
  phone            String?   @unique(map: "profiles_phone_key")
  phone_verified   Boolean   @default(false)
  marketing_agreed Boolean   @default(false)
  nickname         String?
  accounts         Account[]
  sessions         Session[]

  // CM 관련
  cm_applications          cm_applications[] @relation("cm_applications_user")
  cm_applications_reviewed cm_applications[] @relation("cm_applications_reviewer")
  cm_profile               cm_profiles?

  // 클래스/레슨 관련
  class_offerings_as_cm      class_offerings[]   @relation("class_offerings_cm")
  class_offerings_as_creator class_offerings[]   @relation("class_offerings_creator")
  class_enrollments          class_enrollments[]
  cm_settlements_as_cm       cm_settlements[]    @relation("cm_settlements_cm")
  cm_settlements_as_approver cm_settlements[]    @relation("cm_settlements_approver")
  cm_settlements_as_payer    cm_settlements[]    @relation("cm_settlements_payer")

  @@schema("public")
}

// ============================================
// CM (Class Master) 신청 / 공개 프로필
// ============================================

// CM 지원서 (관리자 검토용)
model cm_applications {
  id            String    @id @default(uuid()) @db.Uuid
  user_id       String    @db.Uuid
  name          String
  phone         String
  field         String
  intro         String
  career        String
  portfolio_url String?
  profile_image String?
  can_oneday    Boolean   @default(false)
  can_lesson    Boolean   @default(false)
  subjects      String[]  @default([])
  status        String    @default("PENDING") // PENDING / APPROVED / REJECTED / HOLD
  admin_memo    String?
  reviewed_at   DateTime?
  reviewed_by   String?   @db.Uuid
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  user     users  @relation("cm_applications_user", fields: [user_id], references: [id], onDelete: Cascade)
  reviewer users? @relation("cm_applications_reviewer", fields: [reviewed_by], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([status])
  @@index([created_at(sort: Desc)])
  @@map("cm_applications")
  @@schema("public")
}

// CM 공개 프로필 (승인 후 마이페이지에서 관리)
model cm_profiles {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String   @unique @db.Uuid
  display_name   String
  bio            String?
  career         String?
  subjects       String[] @default([])
  profile_image  String?
  portfolio_url  String?
  is_public      Boolean  @default(true)
  is_active      Boolean  @default(true)
  // 정산 정보 (비공개 — RLS 보호)
  bank_name      String?
  account_number String?
  account_holder String?
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("cm_profiles")
  @@schema("public")
}

// ============================================
// 자유게시판 시스템 (마이그레이션 미적용 상태에서 스키마만 정의)
// ============================================

// 게시글 (카테고리는 자유 텍스트 categoryText; 동일 텍스트 N건 이상이면 UI에서 정식 카테고리로 표시)
model BoardPost {
  id           String   @id @default(cuid())
  categoryText String?  @map("category_text")
  authorId     String   @map("author_id") @db.Uuid
  title        String
  content      String   @db.Text
  views        Int      @default(0)
  isNotice     Boolean  @default(false) @map("is_notice")
  isPinned     Boolean  @default(false) @map("is_pinned")
  isHidden     Boolean  @default(false) @map("is_hidden")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  comments BoardComment[]
  likes    BoardLike[]

  @@index([categoryText])
  @@index([authorId])
  @@index([createdAt])
  @@map("board_posts")
  @@schema("public")
}

// 댓글 (대댓글 지원)
model BoardComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  parentId  String?  @map("parent_id")
  isHidden  Boolean  @default(false) @map("is_hidden")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    BoardPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  BoardComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies BoardComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@map("board_comments")
  @@schema("public")
}

// 좋아요
model BoardLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("board_likes")
  @@schema("public")
}

enum OneDayClassStatus {
  OPEN
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("public")
}

enum ReservationStatus {
  HOLD
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
  CONFIRMED

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELLED
  PARTIAL_REFUNDED
  REFUNDED

  @@schema("public")
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED

  @@schema("public")
}

// ============================================
// 클래스/레슨 + 정산 (Phase 5-A)
// ============================================

// 원데이클래스 / 개인레슨 상품
model class_offerings {
  id               String    @id @default(uuid()) @db.Uuid
  type             String // 'oneday' | 'lesson'
  cm_user_id       String?   @db.Uuid
  title            String
  description      String?
  subject          String? // vocal / dance / act / musical / etc
  duration_minutes Int       @default(60)
  capacity         Int       @default(1)
  price_points     Int
  scheduled_at     DateTime?
  status           String    @default("DRAFT") // DRAFT / OPEN / CLOSED / CANCELLED / COMPLETED
  created_by       String?   @db.Uuid
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  cm          users?              @relation("class_offerings_cm", fields: [cm_user_id], references: [id], onDelete: SetNull)
  creator     users?              @relation("class_offerings_creator", fields: [created_by], references: [id], onDelete: SetNull)
  enrollments class_enrollments[]

  @@index([type, status])
  @@index([cm_user_id])
  @@index([scheduled_at])
  @@map("class_offerings")
  @@schema("public")
}

// 수강 신청 (포인트 HOLD/USED/REFUNDED 흐름)
model class_enrollments {
  id               String    @id @default(uuid()) @db.Uuid
  offering_id      String    @db.Uuid
  user_id          String    @db.Uuid
  status           String    @default("HELD") // PENDING / HELD / COMPLETED / CANCELLED / REFUNDED / NO_SHOW
  points_held      Int       @default(0)
  points_used      Int       @default(0)
  points_refunded  Int       @default(0)
  request_note     String?
  enrolled_at      DateTime  @default(now())
  completed_at     DateTime?
  cancelled_at     DateTime?
  cancelled_reason String?
  updated_at       DateTime  @default(now()) @updatedAt

  offering   class_offerings @relation(fields: [offering_id], references: [id], onDelete: Restrict)
  user       users           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  settlement cm_settlements?

  @@index([user_id])
  @@index([offering_id])
  @@index([status])
  @@map("class_enrollments")
  @@schema("public")
}

// CM 정산 (수업 완료 후 자동 생성, 관리자 승인 → 수동 이체)
model cm_settlements {
  id            String    @id @default(uuid()) @db.Uuid
  enrollment_id String    @unique @db.Uuid
  cm_user_id    String    @db.Uuid
  type          String // 'oneday' | 'lesson'
  base_amount   Int
  ratio         Int // 50 또는 70
  amount        Int // base × ratio / 100
  status        String    @default("PENDING") // PENDING / APPROVED / PAID / FAILED
  approved_at   DateTime?
  approved_by   String?   @db.Uuid
  paid_at       DateTime?
  paid_by       String?   @db.Uuid
  paid_method   String? // 'manual_transfer' / 'auto_api' (추후)
  paid_memo     String?
  failed_reason String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  enrollment class_enrollments @relation(fields: [enrollment_id], references: [id], onDelete: Restrict)
  cm         users             @relation("cm_settlements_cm", fields: [cm_user_id], references: [id], onDelete: Restrict)
  approver   users?            @relation("cm_settlements_approver", fields: [approved_by], references: [id], onDelete: SetNull)
  payer      users?            @relation("cm_settlements_payer", fields: [paid_by], references: [id], onDelete: SetNull)

  @@index([cm_user_id])
  @@index([status])
  @@map("cm_settlements")
  @@schema("public")
}

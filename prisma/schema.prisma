generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model OneDayClass {
  id              String                   @id @default(cuid())
  title           String
  teacherName     String                   @map("teacher_name")
  teacherProfile  String                   @map("teacher_profile")
  teacherImage    String?                  @map("teacher_image")
  classType       String                   @map("class_type")
  description     String
  desiredDate     DateTime                 @map("desired_date")
  durationMinutes Int                      @default(120) @map("duration_minutes")
  minHeadcount    Int                      @default(8) @map("min_headcount")
  maxHeadcount    Int                      @default(15) @map("max_headcount")
  pricePerPerson  Int                      @map("price_per_person")
  status          OneDayClassStatus        @default(OPEN)
  confirmedDate   DateTime?                @map("confirmed_date")
  isPublished     Boolean                  @default(true) @map("is_published")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  applications    OneDayClassApplication[]

  @@map("one_day_classes")
  @@schema("public")
}

model OneDayClassApplication {
  id          String      @id @default(cuid())
  classId     String      @map("class_id")
  userId      String?     @map("user_id") @db.Uuid
  guestName   String      @map("guest_name")
  guestPhone  String      @map("guest_phone")
  guestEmail  String?     @map("guest_email")
  headcount   Int         @default(1)
  message     String?
  isCancelled Boolean     @default(false) @map("is_cancelled")
  createdAt   DateTime    @default(now()) @map("created_at")
  class       OneDayClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("one_day_class_applications")
  @@schema("public")
}

model Room {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  description       String?
  capacity          Int
  sizeM2            Float               @map("size_m2")
  amenities         Json                @default("[]") @map("amenities_json")
  images            Json                @default("[]")
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  pricingRules      PricingRule[]
  reservation_holds reservation_holds[]
  reservations      Reservation[]

  @@map("rooms")
  @@schema("public")
}

model PricingRule {
  id            String   @id @default(cuid())
  roomId        String   @map("room_id")
  label         String
  dayOfWeekMask Int      @map("day_of_week_mask")
  timeStart     String   @map("time_start")
  timeEnd       String   @map("time_end")
  pricePerHour  Int      @map("price_per_hour")
  minHours      Int      @default(1) @map("min_hours")
  isPackage     Boolean  @default(false) @map("is_package")
  packageName   String?  @map("package_name")
  packageHours  Int?     @map("package_hours")
  packagePrice  Int?     @map("package_price")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
  @@schema("public")
}

model Reservation {
  id                String             @id @default(cuid())
  roomId            String             @map("room_id")
  userId            String?            @map("user_id") @db.Uuid
  guestName         String             @map("guest_name")
  guestPhone        String             @map("guest_phone")
  guestEmail        String?            @map("guest_email")
  date              String
  startTime         String             @map("start_time")
  endTime           String             @map("end_time")
  headcount         Int                @default(1)
  status            ReservationStatus  @default(HOLD)
  totalAmount       Int                @map("total_amount")
  memo              String?
  authCode          String?            @map("auth_code")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  reservationType   String?            @map("reservation_type")
  packageType       String?            @map("package_type")
  payment           Payment?
  reservation_holds reservation_holds?
  room              Room               @relation(fields: [roomId], references: [id])
  reviews           reviews?

  @@index([roomId, date])
  @@index([guestPhone])
  @@map("reservations")
  @@schema("public")
}

model ChargePackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  amount      Int
  bonusRate   Float?   @map("bonus_rate")
  bonusPoints Int?     @map("bonus_points")
  totalPoints Int      @map("total_points")
  isPopular   Boolean  @default(false) @map("is_popular")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("charge_packages")
  @@schema("public")
}

model Payment {
  id                 String        @id @default(cuid())
  reservationId      String        @unique @map("reservation_id")
  provider           String        @default("toss")
  providerPaymentKey String?       @map("provider_payment_key")
  orderId            String        @unique @map("order_id")
  amount             Int
  status             PaymentStatus @default(PENDING)
  requestedAt        DateTime      @default(now()) @map("requested_at")
  approvedAt         DateTime?     @map("approved_at")
  rawResponse        Json?         @map("raw_response")
  reservation        Reservation   @relation(fields: [reservationId], references: [id])
  refunds            Refund[]

  @@map("payments")
  @@schema("public")
}

model Refund {
  id          String       @id @default(cuid())
  paymentId   String       @map("payment_id")
  amount      Int
  reason      String
  status      RefundStatus @default(REQUESTED)
  processedAt DateTime?    @map("processed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  payment     Payment      @relation(fields: [paymentId], references: [id])

  @@map("refunds")
  @@schema("public")
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String
  isPublished Boolean  @default(false) @map("is_published")
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("notices")
  @@schema("public")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  content     String
  thumbnail   String?
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("events")
  @@schema("public")
}

model BlockedSlot {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  date      String
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  reason    String   @default("관리자 차단")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId, date])
  @@map("blocked_slots")
  @@schema("public")
}

model ExternalReservation {
  id         String   @id @default(cuid())
  platform   String
  externalId String?  @map("external_id")
  roomType   String   @map("room_type")
  date       String
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  guestName  String   @map("guest_name")
  guestPhone String   @map("guest_phone")
  amount     Int      @default(0)
  status     String   @default("confirmed")
  memo       String?
  syncedAt   DateTime @default(now()) @map("synced_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([platform, date])
  @@index([date])
  @@map("external_reservations")
  @@schema("public")
}

model PaymentLock {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String   @map("user_id") @db.Uuid
  lockType  String   @map("lock_type")
  lockKey   String   @map("lock_key")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, lockType, lockKey])
  @@index([expiresAt], map: "idx_payment_locks_expires")
  @@index([userId], map: "idx_payment_locks_user")
  @@map("payment_locks")
  @@schema("public")
}

model MemberRole {
  email     String   @id
  role      String
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("member_roles")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_PaymentLock {
  id        String   @id
  userId    String   @db.Uuid
  lockType  String
  lockKey   String
  expiresAt DateTime @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([userId, lockType, lockKey])
  @@index([expiresAt], map: "idx_payment_lock_expires")
  @@index([userId], map: "idx_payment_lock_user")
  @@map("PaymentLock")
  @@schema("public")
}

model banned_members {
  email      String   @id
  reason     String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model email_auth_users {
  email         String   @id
  password_hash String
  name          String?
  created_at    DateTime @default(now())
  updated_at    DateTime

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model message_logs {
  id             String   @id
  user_id        String?  @db.Uuid
  reservation_id String?
  phone_number   String
  message_type   String
  content        String
  status         String
  error_message  String?
  message_id     String?
  created_at     DateTime @default(now())

  @@index([created_at(sort: Desc)])
  @@index([reservation_id])
  @@index([user_id])
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model party_reservations {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?   @db.Uuid
  date             DateTime  @db.Date
  start_time       DateTime  @db.Time(6)
  end_time         DateTime  @db.Time(6)
  duration_hours   Decimal   @db.Decimal(4, 2)
  total_amount     Int
  guest_name       String
  guest_phone      String
  guest_email      String?
  headcount        Int?      @default(1)
  status           String?   @default("PAID")
  payment_provider String?
  payment_key      String?
  order_id         String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  cancelled_at     DateTime? @db.Timestamptz(6)

  @@schema("public")
}

model password_reset_tokens {
  token      String    @id
  email      String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([email])
  @@index([expires_at])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model point_transactions {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  type           String
  amount         Int
  balance_after  Int
  description    String?
  reservation_id String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_point_transactions_user")
  @@schema("public")
}

model reservation_holds {
  id             String      @id
  room_id        String
  reservation_id String      @unique
  date           String
  start_time     String
  end_time       String
  expires_at     DateTime
  created_at     DateTime    @default(now())
  reservations   Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  rooms          Room        @relation(fields: [room_id], references: [id])

  @@unique([room_id, date, start_time, end_time])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id             String      @id
  rating         Int
  content        String
  created_at     DateTime    @default(now())
  is_visible     Boolean     @default(false)
  nickname       String?
  reservation_id String      @unique
  reservations   Reservation @relation(fields: [reservation_id], references: [id])

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_points {
  user_id       String    @id @db.Uuid
  balance       Int?      @default(0)
  total_charged Int?      @default(0)
  total_used    Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id               String    @id(map: "profiles_pkey") @db.Uuid
  email            String?   @unique(map: "profiles_email_key")
  name             String?
  avatar_url       String?
  provider         String?
  created_at       DateTime  @default(now())
  updated_at       DateTime
  birth_year       Int?      @db.SmallInt
  phone            String?   @unique(map: "profiles_phone_key")
  phone_verified   Boolean   @default(false)
  marketing_agreed Boolean   @default(false)
  nickname         String?
  accounts         Account[]
  sessions         Session[]

  @@schema("public")
}

// ============================================
// 자유게시판 시스템 (마이그레이션 미적용 상태에서 스키마만 정의)
// ============================================

// 게시판 카테고리 (회원이 생성 가능)
model BoardCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  isOfficial  Boolean  @default(false) @map("is_official")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  posts BoardPost[]

  @@map("board_categories")
  @@schema("public")
}

// 게시글
model BoardPost {
  id          String   @id @default(cuid())
  categoryId  String?  @map("category_id")
  authorId    String   @map("author_id") @db.Uuid
  title       String
  content     String   @db.Text
  views       Int      @default(0)
  isNotice    Boolean  @default(false) @map("is_notice")
  isPinned    Boolean  @default(false) @map("is_pinned")
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category BoardCategory? @relation(fields: [categoryId], references: [id])
  comments BoardComment[]
  likes    BoardLike[]

  @@map("board_posts")
  @@index([categoryId])
  @@index([authorId])
  @@index([createdAt])
  @@schema("public")
}

// 댓글 (대댓글 지원)
model BoardComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  authorId  String   @map("author_id") @db.Uuid
  content   String   @db.Text
  parentId  String?  @map("parent_id")
  isHidden  Boolean  @default(false) @map("is_hidden")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post    BoardPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  BoardComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies BoardComment[] @relation("CommentReplies")

  @@map("board_comments")
  @@index([postId])
  @@index([authorId])
  @@schema("public")
}

// 좋아요
model BoardLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post BoardPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("board_likes")
  @@schema("public")
}

enum OneDayClassStatus {
  OPEN
  CONFIRMED
  CANCELLED
  COMPLETED

  @@schema("public")
}

enum ReservationStatus {
  HOLD
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
  CONFIRMED

  @@schema("public")
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELLED
  PARTIAL_REFUNDED
  REFUNDED

  @@schema("public")
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED

  @@schema("public")
}
